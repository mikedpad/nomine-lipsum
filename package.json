{
  "name": "nomine-lipsum",
  "version": "5.0.0",
  "description": "A random name generator from the most popular names in the United States.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikedpad/nomine-lipsum.git"
  },
  "homepage": "https://github.com/mikedpad/nomine-lipsum#readme",
  "bugs": "https://github.com/mikedpad/nomine-lipsum/issues",
  "author": {
    "name": "Michael Daniel Padilla",
    "email": "michaeldpadilla@gmail.com",
    "url": "https://mikedpad.com"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "lib"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/umd/index.cjs",
      "default": "./lib/index.js"
    }
  },
  "main": "./lib/umd/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "unpkg": "./lib/umd/index.cjs",
  "jsdelivr": "./lib/umd/index.cjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "lorem",
    "ipsum",
    "lipsum",
    "placeholder",
    "random",
    "name",
    "generator",
    "faker",
    "popular",
    "usa"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:db": "node --loader ts-node/esm src/__generate__/generateData.ts",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.json",
    "build:lib": "rimraf lib && rollup -c && npm run build:types",
    "build": "npm run build:db && npm run build:lib",
    "prepare": "npm run build:lib",
    "prepublishOnly": "npm run lint && npm run format:check && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.1.1",
    "adm-zip": "^0.6.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "got": "^15.1.0",
    "ora": "^9.4.1",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
